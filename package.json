{
  "name": "buddy-ide-companion",
  "displayName": "Buddy - IDE Companion",
  "description": "A playful IDE companion that reacts to your coding flow from the VS Code sidebar.",
  "version": "0.8.0",
  "publisher": "connor-partington",
  "author": "Connor",
  "license": "LGPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Connor-Partington/buddy.git"
  },
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "companion",
    "assistant",
    "productivity",
    "sidebar",
    "fun"
  ],
  "activationEvents": [
    "onUri",
    "onCommand:buddy.kill",
    "onCommand:buddy.spawnCookie",
    "onCommand:buddy.spawnCoffee",
    "onCommand:buddy.spawnSandwich",
    "onCommand:buddy.spawnCake",
    "onCommand:buddy.toggleBreakPrompt",
    "onCommand:buddy.toggleFocusMode",
    "onCommand:buddy.removeHeart",
    "onCommand:buddy.addXp",
    "onCommand:buddy.resetXp",
    "onCommand:buddy.resetAllState",
    "onCommand:buddy.runDemo",
    "onCommand:buddy.setXpMultiplier",
    "onCommand:buddy.showDebugMonitor",
    "onCommand:buddy.revive",
    "onCommand:buddy.showSidebar",
    "onStartupFinished",
    "onView:buddy.companion"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "buddy",
          "title": "Buddy",
          "icon": "media/buddy.svg"
        }
      ]
    },
    "views": {
      "buddy": [
        {
          "id": "buddy.companion",
          "name": "Buddy",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "buddy.wakeUp",
        "title": "Buddy: Wake Up"
      },
      {
        "command": "buddy.setState.idle",
        "title": "Buddy: Set State Idle"
      },
      {
        "command": "buddy.setState.typing",
        "title": "Buddy: Set State Typing"
      },
      {
        "command": "buddy.setState.searching",
        "title": "Buddy: Set State Searching"
      },
      {
        "command": "buddy.setState.thinking",
        "title": "Buddy: Set State Thinking"
      },
      {
        "command": "buddy.setState.sleeping",
        "title": "Buddy: Set State Sleeping"
      },
      {
        "command": "buddy.setState.happy",
        "title": "Buddy: Set State Happy"
      },
      {
        "command": "buddy.setState.jump",
        "title": "Buddy: Set State Jump"
      },
      {
        "command": "buddy.previewAnimations",
        "title": "Buddy: Preview Animations"
      },
      {
        "command": "buddy.showSidebar",
        "title": "Buddy: Show Sidebar"
      },
      {
        "command": "buddy.toggleSize",
        "title": "Buddy: Toggle Size"
      },
      {
        "command": "buddy.spawnCookie",
        "title": "Buddy: Spawn Cookie",
        "icon": {
          "light": "media/cookie-light.svg",
          "dark": "media/cookie-dark.svg"
        }
      },
      {
        "command": "buddy.spawnCoffee",
        "title": "Buddy: Spawn Coffee"
      },
      {
        "command": "buddy.spawnSandwich",
        "title": "Buddy: Spawn Sandwich"
      },
      {
        "command": "buddy.spawnCake",
        "title": "Buddy: Spawn Cake"
      },
      {
        "command": "buddy.toggleBreakPrompt",
        "title": "Buddy: Toggle Break Prompt",
        "icon": {
          "light": "media/break-light.svg",
          "dark": "media/break-dark.svg"
        }
      },
      {
        "command": "buddy.toggleFocusMode",
        "title": "Buddy: Toggle Focus Mode"
      },
      {
        "command": "buddy.revive",
        "title": "Buddy: Revive",
        "icon": {
          "light": "media/revive-light.svg",
          "dark": "media/revive-dark.svg"
        }
      },
      {
        "command": "buddy.kill",
        "title": "Buddy: Kill",
        "icon": {
          "light": "media/death-light.svg",
          "dark": "media/death-dark.svg"
        }
      },
      {
        "command": "buddy.removeHeart",
        "title": "Buddy: Remove Heart"
      },
      {
        "command": "buddy.addXp",
        "title": "Buddy: Add XP"
      },
      {
        "command": "buddy.resetXp",
        "title": "Buddy: Reset XP"
      },
      {
        "command": "buddy.resetAllState",
        "title": "Buddy: Reset All State"
      },
      {
        "command": "buddy.runDemo",
        "title": "Buddy: Run Feature Demo"
      },
      {
        "command": "buddy.setXpMultiplier",
        "title": "Buddy: Set XP Multiplier"
      },
      {
        "command": "buddy.showDebugMonitor",
        "title": "Buddy: Show Debug Dashboard"
      },
      {
        "command": "buddy.openLevelUpGallery",
        "title": "Buddy: Open Level-Up Gallery"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "buddy.spawnCookie",
          "when": "view == buddy.companion && !buddy.focusMode",
          "group": "navigation@1"
        },
        {
          "command": "buddy.revive",
          "when": "view == buddy.companion && !buddy.focusMode",
          "group": "navigation@2"
        },
        {
          "command": "buddy.kill",
          "when": "view == buddy.companion && !buddy.focusMode",
          "group": "navigation@3"
        },
        {
          "command": "buddy.toggleBreakPrompt",
          "when": "view == buddy.companion && !buddy.focusMode",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "Buddy",
      "properties": {
        "buddy.milestoneReactions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable visual and XP reactions for Buddy milestones."
        },
        "buddy.milestoneReactions.focusedSessionMinutes": {
          "type": "number",
          "default": 90,
          "minimum": 1,
          "description": "Minutes of continuous VS Code window focus before Buddy triggers the long focused session milestone."
        },
        "buddy.milestoneReactions.xpBonus": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "description": "XP awarded for each Buddy milestone reaction."
        },
        "buddy.care.heartDrainIntervalMinutes": {
          "type": "number",
          "default": 180,
          "minimum": 1,
          "description": "Minutes between automatic Buddy heart loss events."
        },
        "buddy.care.breakPromptIntervalMinutes": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "description": "Minutes between automatic Buddy break reminder prompts."
        },
        "buddy.care.xpMultiplier": {
          "type": "number",
          "default": 1,
          "minimum": 0.1,
          "description": "Base multiplier applied to future Buddy XP gains."
        },
        "buddy.care.deathPenaltyPercent": {
          "type": "number",
          "default": 25,
          "minimum": 0,
          "maximum": 100,
          "description": "Percent of the current level XP requirement Buddy loses when he dies."
        },
        "buddy.care.canDie": {
          "type": "boolean",
          "default": true,
          "description": "Allow Buddy to die when red hearts reach zero."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "demo": "node scripts/run-demo.js",
    "package": "vsce package --allow-missing-repository --baseContentUrl https://github.com/Connor-Partington/buddy/blob/main --baseImagesUrl https://raw.githubusercontent.com/Connor-Partington/buddy/main",
    "publish": "vsce publish --baseContentUrl https://github.com/Connor-Partington/buddy/blob/main --baseImagesUrl https://raw.githubusercontent.com/Connor-Partington/buddy/main",
    "lint": "eslint src",
    "test": "npm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.59.4",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3"
  }
}
