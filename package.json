{
  "name": "docfox",
  "displayName": "Luna",
  "description": "A lightweight local VS Code companion for Markdown copyediting workflows.",
  "version": "0.0.19",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:docfox.showSidebar",
    "onLanguage:markdown",
    "onView:docfox.companion"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "docfox",
          "title": "Luna",
          "icon": "media/docfox.svg"
        }
      ]
    },
    "views": {
      "docfox": [
        {
          "id": "docfox.companion",
          "name": "Luna",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "docfox.helloWorld",
        "title": "Luna: Hello World"
      },
      {
        "command": "docfox.setState.idle",
        "title": "Luna: Set State Idle"
      },
      {
        "command": "docfox.setState.typing",
        "title": "Luna: Set State Typing"
      },
      {
        "command": "docfox.setState.searching",
        "title": "Luna: Set State Searching"
      },
      {
        "command": "docfox.setState.thinking",
        "title": "Luna: Set State Thinking"
      },
      {
        "command": "docfox.setState.sleeping",
        "title": "Luna: Set State Sleeping"
      },
      {
        "command": "docfox.setState.happy",
        "title": "Luna: Set State Happy"
      },
      {
        "command": "docfox.setState.panic",
        "title": "Luna: Set State Panic"
      },
      {
        "command": "docfox.previewAnimations",
        "title": "Luna: Preview Animations"
      },
      {
        "command": "docfox.showSidebar",
        "title": "Luna: Show Sidebar"
      },
      {
        "command": "docfox.toggleSounds",
        "title": "Luna: Toggle Sounds"
      },
      {
        "command": "docfox.toggleFrameAnimations",
        "title": "Luna: Toggle Animated Sprites"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "install:local": "scripts/install-latest.sh",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  }
}
